{
  "name": "contextos",
  "displayName": "contextOS AI",
  "description": "AI-native sidebar connecting your workspace code directly to live GitHub Pull Requests, Jira issues, and team discussions.",
  "version": "0.0.4",
  "publisher": "AmanShaikh",
  "author": {
    "name": "Aman Shaikh"
  },
  "license": "MIT",
  "icon": "image/logo.png",
  "engines": {
    "vscode": "^1.116.0"
  },
  "extensionDependencies": [
    "vscode.git"
  ],
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "github",
    "jira",
    "pull request",
    "context",
    "summary",
    "workspace"
  ],
  "activationEvents": [
    "onView:contextos.sidebarView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "contextos-sidebar",
          "title": "contextOS",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "contextos-sidebar": [
        {
          "type": "webview",
          "id": "contextos.sidebarView",
          "name": "Project Insight"
        },
        {
          "type": "tree",
          "id": "contextos.prBadge",
          "name": "PR Count",
          "when": "false"
        }
      ]
    },
    "commands": [
      {
        "command": "contextos.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "package:vsix": "vsce package --no-dependencies",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/express-rate-limit": "^6.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.116.0",
    "@types/vscode-webview": "^1.57.5",
    "@types/ws": "^8.18.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.11"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ws": "^8.21.0"
  }
}