{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./src", 
    "outDir": "./dist",

    /* Environment Settings */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "lib": ["ESNext"],
    "types": ["node"],

    /* Interop & Reliability */
    "esModuleInterop": true,            
    "skipLibCheck": true,               
    "forceConsistentCasingInFileNames": true,

    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "isolatedModules": true,

    /* Modern Module Handling */
    "moduleDetection": "force",
    "verbatimModuleSyntax": false,      
    
    /* Other Outputs */
    "sourceMap": true,
    "declaration": true
  },
  "include": ["src/**/*"]             // Clean and isolated to your source files!
}